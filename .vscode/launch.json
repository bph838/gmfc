{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debug in Chrome",
      "url": "http://localhost:8080/club/selling/",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "webpack://gmfc/./*": "${webRoot}/*"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug lapmonitor.js",
      "program": "${workspaceFolder}/utils/lapmonitor/lapmonitor.js",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
